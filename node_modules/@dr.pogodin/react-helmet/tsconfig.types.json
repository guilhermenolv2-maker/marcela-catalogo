{
  "extends": "@tsconfig/recommended",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "module": "Preserve",
    "noUncheckedIndexedAccess": true,
    "outDir": "build/types",
    "rootDir": "src",
    "target": "es2017",
    "verbatimModuleSyntax": true
  },
  "include": ["src"]
}
